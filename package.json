{
  "name": "pocket-motion-counter",
  "private": true,
  "version": "1.0.0",
  "description": "Pocket Motion Counter Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:lab": "npm run dev --workspace=apps/sensor-lab",
    "dev:demo": "npm run dev --workspace=apps/counter-demo",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
